# Vercel KV / Upstash Redis (job storage)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash QStash (background pipeline)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Claude (primary report generator)
ANTHROPIC_API_KEY=
FOLDEX_CLAUDE_MODEL=claude-sonnet-4-20250514

# Groq (fallback report generator)
GROQ_API_KEY=
FOLDEX_GROQ_URL=https://api.groq.com/openai/v1/chat/completions
FOLDEX_GROQ_MODEL=llama-3.3-70b-versatile

# External-API behavior
FOLDEX_GNOMAD_DATASET=gnomad_r4
FOLDEX_PREPRINT_LOOKBACK_DAYS=730
# Set to 1 to skip live API calls and run on stub data only.
FOLDEX_DISABLE_LIVE_APIS=

# Public app URL used to build worker callbacks (auto-set on Vercel).
# Required only for local development if you want QStash to invoke localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000
